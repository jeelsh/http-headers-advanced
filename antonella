    /**
     * Add React menu and shortcode entries to Config.php
     */
    private function addReactMenuToConfig()
    {
        $configPath = $this->dir . DIRECTORY_SEPARATOR . 'src' . DIRECTORY_SEPARATOR . 'Config.php';
        
        if (!file_exists($configPath)) {
            $this->showInfo("Config.php not found, skipping menu addition");
            return;
        }
        
        $content = file_get_contents($configPath);
        $changed = false;
        
        // Add menu entry if not already present
        if (strpos($content, 'ExampleReactController::helloWorldPage') === false) {
            $reactMenuEntry = ",\n        [\n"
                . "            'path' => ['page'],\n"
                . "            'name' => 'Hello World with React',\n"
                . "            'function' => __NAMESPACE__ . \"\Controllers\ExampleReactController::helloWorldPage\",\n"
                . "            'icon' => 'antonella-icon.png',\n"
                . "            'slug' => 'antonella-react-hello',\n"
                . "        ]";

            $menuMarker = "// Add your custom admin pages here";
            if (strpos($content, $menuMarker) !== false) {
                $content = str_replace($menuMarker, $reactMenuEntry . "\n        " . $menuMarker, $content);
                $changed = true;
                $this->showSuccess("React menu added to Config.php!");
            } else {
                $this->showInfo("Could not find menu insertion point in Config.php");
                $this->showInfo("Please add the React menu entry manually");
            }
        } else {
            $this->showInfo("React menu already exists in Config.php");
        }

        // Add shortcode entry if not already present
        if (strpos($content, "ExampleReactController::helloWorld'") === false
            && strpos($content, 'ExampleReactController::helloWorld"') === false) {
            $shortcodeEntry = "['hello_world', __NAMESPACE__ . '\Controllers\ExampleReactController::helloWorld']";

            // Find the shortcodes array and insert before its closing bracket
            $shortcodeMarker = '// Add your custom shortcodes here';
            if (strpos($content, $shortcodeMarker) !== false) {
                $content = str_replace(
                    $shortcodeMarker,
                    $shortcodeEntry . ",\n        " . $shortcodeMarker,
                    $content
                );
                $changed = true;
                $this->showSuccess("React shortcode added to Config.php!");
            } elseif (preg_match('/(\$shortcodes\s*=\s*\[)(.*?)(\];)/s', $content, $matches)) {
                $arrayContent = trim($matches[2]);
                if ($arrayContent === '') {
                    $replacement = $matches[1] . "\n        " . $shortcodeEntry . "\n    " . $matches[3];
                } else {
                    $replacement = $matches[1] . $matches[2] . ",\n        " . $shortcodeEntry . "\n    " . $matches[3];
                }
                $content = str_replace($matches[0], $replacement, $content);
                $changed = true;
                $this->showSuccess("React shortcode added to Config.php!");
            } else {
                $this->showInfo("Could not find shortcodes insertion point in Config.php");
            }
        } else {
            $this->showInfo("React shortcode already exists in Config.php");
        }

        if ($changed) {
            file_put_contents($configPath, $content);
        }
    }

