        padding: '20px',
        maxWidth: '800px',
        margin: '0 auto'
    }
};
JSX;
    }

    /**
     * Generate controller file
     */
    public function makeController($data)
    {
        $className = $this->validateInput($data, 2, "Controller name is required");
        $namespace = $this->readNamespace();

        // Parse --react flag
        $reactFlag = $this->parseReactFlag($data);
        $isReact = $reactFlag !== null;
        $componentName = $reactFlag;

        // If --react flag without value, derive component name from controller
        if ($isReact && empty($componentName)) {
            $componentName = str_replace('Controller', '', $className);
        }

        $controllerDir = $this->dir . DIRECTORY_SEPARATOR . "src" . DIRECTORY_SEPARATOR . "Controllers";
        $this->createDirectoryIfNotExists($controllerDir);

        $filePath = $controllerDir . DIRECTORY_SEPARATOR . "$className.php";
        
        // Use React template if --react flag is present
        if ($isReact) {
            $template = $this->getReactControllerTemplate($className, $namespace, $componentName);
        } else {
            $template = $this->getTemplate('controller', $className, $namespace);
        }

        if (file_put_contents($filePath, $template)) {
            $this->showSuccess("Controller $className.php created in src/Controllers/");
            
            // Create React component if --react flag is present AND React is integrated
            if ($isReact) {
                if ($this->isReactIntegrated()) {
                    $this->createReactComponent($componentName);
                } else {
                    $this->showInfo("⚠️  React integration not detected. Controller created without React component.");
                    $this->showInfo("   Run 'php antonella add react' to add React integration.");
                }
            }
        } else {
            $this->showError("Failed to create controller file");
        }

        exit(0);
    }

    /**
     * Generate widget file
     */
    public function makeWidget($data)
    {
        $className = $this->validateInput($data, 2, "Widget name is required");
        $namespace = $this->readNamespace();

        $filePath = $this->dir . DIRECTORY_SEPARATOR . "src" . DIRECTORY_SEPARATOR . "$className.php";
        $template = $this->getTemplate('widget', $className, $namespace);

        if (file_put_contents($filePath, $template)) {
            $this->showSuccess("Widget $className.php created in src/");
        } else {
            $this->showError("Failed to create widget file");
        }

        exit(0);
    }

    /**
     * Generate helper file
     */
    public function makeHelper($data)
    {
        $functionName = $this->validateInput($data, 2, "Helper function name is required");

        $helperDir = $this->dir . DIRECTORY_SEPARATOR . "src" . DIRECTORY_SEPARATOR . "Helpers";
        $this->createDirectoryIfNotExists($helperDir);

        $filePath = $helperDir . DIRECTORY_SEPARATOR . "$functionName.php";
        $template = $this->getTemplate('helper', $functionName, '');

        if (file_put_contents($filePath, $template)) {
            $this->showSuccess("Helper $functionName.php created in src/Helpers/");
        } else {
            $this->showError("Failed to create helper file");
        }

        exit(0);
    }

    /**
     * Generate React component file
     * Supports subfolders: php antonella react Texts/TextInput
     */
    public function makeReactComponent($data)
    {
        // Check if React integration exists
        if (!$this->isReactIntegrated()) {
            $this->showError("⚠️  React integration not detected.\n   Please run 'php antonella add react' first to add React integration.");
        }

        $componentPath = $this->validateInput($data, 2, "Component name is required");
        
        $pagesDir = $this->dir . DIRECTORY_SEPARATOR . 'resources' . DIRECTORY_SEPARATOR . 'js' . DIRECTORY_SEPARATOR . 'Pages';
        
        if (!is_dir($pagesDir)) {
            $this->showError("React Pages directory not found. Please run 'php antonella add react' first.");
        }

        // Parse component path (supports subfolders like Texts/TextInput)
        $pathParts = explode('/', $componentPath);
        $componentName = array_pop($pathParts); // Last part is the component name
        
        // Build full directory path with subfolders
        $targetDir = $pagesDir;
        if (!empty($pathParts)) {
            foreach ($pathParts as $folder) {
                $targetDir .= DIRECTORY_SEPARATOR . $folder;
            }
            // Create subfolder if it doesn't exist
            $this->createDirectoryIfNotExists($targetDir);
        }

        $fullPath = $targetDir . DIRECTORY_SEPARATOR . "$componentName.jsx";
        
        if (file_exists($fullPath)) {
            $this->showError("Component $componentPath.jsx already exists!");
        }

        $template = $this->getReactComponentTemplate($componentName);
        
        if (file_put_contents($fullPath, $template)) {
            $relativePath = !empty($pathParts) ? implode('/', $pathParts) . '/' . $componentName : $componentName;
            $this->showSuccess("⚛️  React component created: resources/js/Pages/$relativePath.jsx");
        } else {
            $this->showError("Failed to create React component file");
        }

        exit(0);
    }

    /**
     * Docker environment management
     */
    public function runDocker($data)
    {
        $this->showInfo("Starting Docker environment...");
        $command = 'docker-compose up' . (isset($data[2]) && $data[2] === '-d' ? ' -d' : '');
        exec($command);
        $this->showSuccess("Docker environment started!");
    }

    /**
     * Module management
     */
    public function removeModule($data)
    {
        $module = $data[2] ?? '';

        switch ($module) {
            case 'blade':
                return $this->removeBlade();
            case 'dd':
                return $this->removeDD();
            case 'model':
                return $this->removeModel();
            case 'react':
                return $this->removeReact();
            default:
                $this->showError("Module '$module' not supported for removal. Available: blade, dd, model, react");
        }
    }

    public function addModule($data)
    {
        $module = $data[2] ?? '';

        switch ($module) {
            case 'blade':
                return $this->addBlade();
            case 'dd':
                return $this->addDD();
            case 'model':
                return $this->addModel();
            case 'action':
                return $this->showActions($data);
            case 'react':
                return $this->addReact();
            default:
                $this->showError("Module '$module' not supported. Available: blade, dd, model, action, react");
        }
    }

