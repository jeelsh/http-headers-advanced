    private function createReactComponent($componentName)
    {
        $pagesDir = $this->dir . DIRECTORY_SEPARATOR . 'resources' . DIRECTORY_SEPARATOR . 'js' . DIRECTORY_SEPARATOR . 'Pages';
        
        if (!is_dir($pagesDir)) {
            $this->showError("React Pages directory not found. Please run 'php antonella add react' first.");
            return;
        }

        $componentPath = $pagesDir . DIRECTORY_SEPARATOR . "$componentName.jsx";
        
        if (file_exists($componentPath)) {
            $this->showInfo("⚠️  Component $componentName.jsx already exists, skipping creation.");
            return;
        }

        $template = $this->getReactComponentTemplate($componentName);
        
        if (file_put_contents($componentPath, $template)) {
            $this->showSuccess("⚛️  React component $componentName.jsx created in resources/js/Pages/");
        } else {
            $this->showError("Failed to create React component file");
        }
    }

    private function getReactComponentTemplate($componentName)
    {
        return <<<JSX
import React from 'react';

export default function $componentName() {
    return (
        <div style={styles.container}>
            <h1>$componentName Component</h1>
            <p>This is a React component generated by Antonella Framework.</p>
        </div>
    );
}

const styles = {
