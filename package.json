{
    "name": "http-headers-advanced",
    "version": "1.0.0",
    "description": "WordPress plugin with React integration",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "i18n": "wp i18n make-pot . languages/http-headers-advanced.pot --exclude=node_modules,vendor,assets/dist,storage/cache",
        "i18n:json": "wp i18n make-json languages/ --no-purge",
        "i18n:update": "npm run i18n:json && node scripts/update-translations.js"
    },
    "dependencies": {
        "@base-ui/react": "^1.6.0",
        "@fontsource-variable/geist": "^5.2.9",
        "@fontsource-variable/inter": "^5.2.8",
        "@tailwindcss/vite": "^4.3.2",
        "@wordpress/i18n": "^6.13.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.24.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-router-dom": "^7.18.1",
        "shadcn": "^4.13.0",
        "shadcn-ui": "^0.9.5",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.2",
        "tw-animate-css": "^1.4.0"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^5.1.3",
        "vite": "^7.3.1"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    }
}